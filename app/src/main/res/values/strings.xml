    <!-- Help dialog -->
    <string name="help_message">AuthEase generates time-based one-time passwords (TOTP) for your accounts.\n\n• Tap + to add a new account via QR code or manual entry.\n• Tap the copy icon to copy the code to clipboard.\n• Swipe or long-press an account to delete it.\n• Use Export to back up your secrets and Import to restore them.\n\nFor security, never share your backup file or secret keys.</string>

    <!-- About dialog -->
    <string name="about_message">AuthEase v1.0\n\nA secure, offline two-factor authentication app.\n\nBuilt with Material Design 3, Room, Hilt, and Navigation Component.\n\nYour secrets never leave your device.</string>
