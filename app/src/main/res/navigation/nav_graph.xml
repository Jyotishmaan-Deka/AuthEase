<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.deadlyord.authease.ui.home.HomeFragment"
        android:label="Authenticator"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_homeFragment_to_addAccountFragment"
            app:destination="@id/addAccountFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <action
            android:id="@+id/action_homeFragment_to_settingsFragment"
            app:destination="@id/settingsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/addAccountFragment"
        android:name="com.deadlyord.authease.ui.addaccount.AddAccountFragment"
        android:label="Add Account"
        tools:layout="@layout/fragment_add_account">

        <action
            android:id="@+id/action_addAccountFragment_to_qrScannerFragment"
            app:destination="@id/qrScannerFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/qrScannerFragment"
        android:name="com.deadlyord.authease.ui.scanner.QRScannerFragment"
        android:label="Scan QR Code"
        tools:layout="@layout/fragment_qr_scanner" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.deadlyord.authease.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

</navigation>
