<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="?attr/colorPrimary">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_gravity="center">

        <ImageView
            android:id="@+id/splashIcon"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_shield_lock"
            android:contentDescription="AuthEase logo"
            android:scaleX="0.7"
            android:scaleY="0.7"
            app:tint="?attr/colorOnPrimary" />

        <TextView
            android:id="@+id/splashAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.03"
            android:text="@string/app_name"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/splashTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alpha="0.8"
            android:text="@string/splash_tagline"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="14sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/splashVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/splash_version"
        android:textColor="?attr/colorOnPrimary"
        android:textSize="12sp"
        android:alpha="0.6"
        android:layout_marginBottom="32dp" />

</LinearLayout>